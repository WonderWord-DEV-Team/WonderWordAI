# ====================================================================
# Python Environment & Cache
# ====================================================================
# Ignore compiled Python files (clutter)
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore local virtual environments (prevents uploading gigabytes of dependencies)
venv/
env/
.venv/

# ====================================================================
# Security & Secrets (CRITICAL)
# ====================================================================
# Secret environment variables (never put passwords or private keys on GitHub!)
.env
.env.local

# ====================================================================
# Operating System files
# ====================================================================
# Ignore hidden system files generated by Mac and Windows
.DS_Store
Thumbs.db
